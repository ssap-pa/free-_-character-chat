      "binding": "DB",
      "database_name": "dohajun-chat-production",
      "database_id": "32eb88ec-d290-485b-86fd-23b124e28e5c"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "58984182f2b444a88ff4eb93ba6108e6"
    }
  ]
}
